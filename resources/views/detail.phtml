declare(strict_types=1);

/**
 * @var string $title
 * @var Tree $tree
 * @var Transcription $transcription
 * @var array<int, TranscriptionRevision> $revisions
 * @var ?string $note_text
 * @var ?Source $source
 * @var ?Media $media_object
 * @var array<int,MediaFile> $media_files
 */

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Media;
use Fisharebest\Webtrees\MediaFile;
use Fisharebest\Webtrees\Source;
use Fisharebest\Webtrees\Tree;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Entity\Transcription;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Entity\TranscriptionRevision;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\PrimaryForm;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\PrimaryLanguage;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\PrimaryScript;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\ProviderLabel;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\TranscriptionStatus;

?>

<h2><?= e($title) ?>: <?= e($transcription->title) ?></h2>

<p>
    <a class="btn btn-secondary" href="<?= e(route('source-transcription-dashboard', ['tree' => $tree->name()])) ?>">
        <?= I18N::translate('Back to dashboard') ?>
    </a>
</p>

<div class="alert alert-info">
    <?= I18N::translate('The current webtrees NOTE is used as a working copy. Changes are only archived when saved as a new revision.') ?>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">
                <?= I18N::translate('Source') ?>
            </div>

            <div class="card-body">
                <dl>
                    <dt><?= I18N::translate('Source') ?></dt>
                    <dd>
                        <?php if ($source) : ?>
                            <a href="<?= e($source->url()) ?>">
                                <?= e($source->fullName()) ?>
                            </a>
                        <?php endif ?>
                    </dd>

                    <dt><?= I18N::translate('Media XREF') ?></dt>
                    <dd>
                        <?php if ($media_object) : ?>
                            <a href="<?= e($media_object->url()) ?>">
                                <?= e($media_object->fullName()) ?>
                            </a>
                        <?php else : ?>
                            <span class="text-muted"><?= I18N::translate('No media object selected.') ?></span>
                        <?php endif ?>
                    </dd>

                    <dt><?= I18N::translate('Provider') ?></dt>
                    <dd><?= e(ProviderLabel::label($transcription->provider_key)) ?></dd>

                    <dt><?= I18N::translate('Status') ?></dt>
                    <dd><?= e(TranscriptionStatus::labels()[$transcription->status]) ?></dd>

                    <dt><?= I18N::translate('Current NOTE') ?></dt>
                    <dd>
                        <?php if ($transcription->current_note_xref !== null) : ?>
                            <code><?= e($transcription->current_note_xref) ?></code>
                        <?php else : ?>
                            <span class="text-muted"><?= I18N::translate('None') ?></span>
                        <?php endif ?>
                    </dd>

                    <dt><?= I18N::translate('Primary language') ?></dt>
                    <dd><?= e(PrimaryLanguage::label($transcription->primary_language_tag)) ?></dd>

                    <dt><?= I18N::translate('Primary script') ?></dt>
                    <dd><?= e(PrimaryScript::label($transcription->primary_script_tag)) ?></dd>

                    <dt><?= I18N::translate('Primary form') ?></dt>
                    <dd><?= e(PrimaryForm::label($transcription->primary_form)) ?></dd>

                    <dt><?= I18N::translate('Tag NOTE') ?></dt>
                    <dd>
                        <?php if ($transcription->tag_note_xref !== null) : ?>
                            <code><?= e($transcription->tag_note_xref) ?></code>
                        <?php else : ?>
                            <span class="text-muted"><?= I18N::translate('None') ?></span>
                        <?php endif ?>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <?= I18N::translate('Media preview') ?>
            </div>

            <div class="card-body">
                <?php if ($media_object === null) : ?>
                    <div class="alert alert-secondary mb-0">
                        <?= I18N::translate('No media object selected.') ?>
                    </div>
                <?php elseif ($media_files === []) : ?>
                    <div class="alert alert-warning mb-0">
                        <?= I18N::translate('No media files found for this media object.') ?>
                    </div>
                <?php else : ?>
                <?php if (count($media_files) > 1) : ?>
                    <div class="mb-3">
                        <label class="form-label" for="media-file-select">
                            <?= I18N::translate('Media file') ?>
                        </label>

                        <select class="form-select" id="media-file-select">
                            <?php foreach ($media_files as $index => $file) : ?>
                                <option value="<?= e((string) $index) ?>">
                                    <?= e($file->basename()) ?>
                                </option>
                            <?php endforeach ?>
                        </select>
                    </div>
                <?php endif ?>

                <?php foreach ($media_files as $index => $file) : ?>
                    <div
                            class="source-transcription-media-preview"
                            data-media-file-index="<?= e((string) $index) ?>"
                            style="<?= $index === 0 ? '' : 'display:none' ?>"
                    >
                        <?php if ($file->isImage()) : ?>
                            <div class="border p-2 text-center">
                                <?= $file->displayImage(900, 900, 'contain', [
                                        'class' => 'img-fluid',
                                ]) ?>
                            </div>
                        <?php else : ?>
                            <div class="alert alert-secondary">
                                <?= I18N::translate('This media file cannot be previewed here.') ?>
                            </div>
                            <p>
                                <?= e($file->basename()) ?>
                            </p>
                        <?php endif ?>
                    </div>
                <?php endforeach ?>

                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const select = document.getElementById('media-file-select');

                            if (!select) {
                                return;
                            }

                            select.addEventListener('change', function () {
                                document.querySelectorAll('.source-transcription-media-preview').forEach(function (element) {
                                    element.style.display = element.dataset.mediaFileIndex === select.value ? '' : 'none';
                                });
                            });
                        });
                    </script>

                <?php endif ?>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <?= I18N::translate('Active webtrees NOTE') ?>
            </div>

            <div class="card-body">
                <form method="post" action="<?= e(route('source-transcription-update-note', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>">
                    <?= csrf_field() ?>

                    <textarea
                        class="form-control font-monospace"
                        name="note_text"
                        rows="24"
                    ><?= e((string) $note_text) ?></textarea>

                    <div class="mt-3 d-flex gap-2">
                        <button class="btn btn-primary" type="submit">
                            <?= I18N::translate('Save NOTE') ?>
                        </button>
                    </div>
                </form>

                <form method="post" class="mt-2" action="<?= e(route('source-transcription-save-note-as-revision', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>">
                    <?= csrf_field() ?>

                    <button class="btn btn-success" type="submit">
                        <?= I18N::translate('Archive as new revision') ?>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<hr>

<h3><?= I18N::translate('Revision history') ?></h3>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th><?= I18N::translate('Revision') ?></th>
            <th><?= I18N::translate('Transcription Provider') ?></th>
            <th><?= I18N::translate('Origin') ?></th>
            <th><?= I18N::translate('Current') ?></th>
            <th><?= I18N::translate('Text') ?></th>
        </tr>
    </thead>

    <tbody>
        <?php foreach ($revisions as $revision) : ?>
            <tr>
                <td><?= e((string) $revision->revision_no) ?></td>
                <td><?= e(ProviderLabel::label($revision->provider_key)) ?></td>
                <td><?= e($revision->origin_type) ?></td>
                <td><?= $revision->is_current_revision ? '✓' : '' ?></td>
                <td>
                    <pre class="mb-0"><?= e(mb_substr($revision->content_text, 0, 500)) ?></pre>
                </td>
            </tr>
        <?php endforeach ?>
    </tbody>
</table>
